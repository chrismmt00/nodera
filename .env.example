# App
NODE_ENV=development
APP_URL=http://localhost:3000
API_BASE_URL=http://localhost:3000/api/v1

# Database
DATABASE_URL=postgresql://nodera:nodera@localhost:5433/nodera?schema=public

# Dispatcher
DISPATCH_INTERVAL_MS=1000
PROVIDER_OFFLINE_AFTER_MS=120000
JOB_MAX_ATTEMPTS=3

# Provider enrollment
PROVIDER_ENROLL_SECRET=replace-me-in-local-env

# Provider agent (dev)
NODE_NAME=dev-agent
AGENT_CONCURRENCY=1
AGENT_JOBS_DIR=agent-jobs
AGENT_POLL_MS=1000
AGENT_WORKER_MEMORY=2g
AGENT_WORKER_CPUS=2
OLLAMA_URL=http://host.docker.internal:11434
# Absolute path to the docker CLI if it is not on PATH
DOCKER_BIN=docker

# Artifacts and storage
STORAGE_BACKEND=local
STORAGE_ROOT=storage
INLINE_ARTIFACT_MAX_BYTES=262144
MAX_ARTIFACTS_PER_RUN=10
MAX_ARTIFACT_TOTAL_BYTES=52428800

# Cloudflare R2
R2_ACCOUNT_ID=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_REGION=auto
R2_UPLOAD_URL_TTL_S=300

# Webhooks
WEBHOOK_MAX_ATTEMPTS=5
WEBHOOK_BACKOFF_S=60,300,900,3600,21600
WEBHOOK_TIMEOUT_MS=10000
WEBHOOK_BATCH_SIZE=10
WEBHOOK_PORT=8787

# Storage signing (local backend upload URLs)
STORAGE_SIGNING_SECRET=replace-me-in-local-env

# Webhook receiver harness
WEBHOOK_FAILS_BEFORE_SUCCESS=2

# Auth / sessions
SESSION_SECRET=replace-me-in-local-env
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
