# Copy to deploy/.env. Never commit deploy/.env.
# POSTGRES_PASSWORD and the password embedded in DATABASE_URL must match.
POSTGRES_PASSWORD=replace-with-a-long-random-password
DATABASE_URL=postgresql://nodera:replace-with-the-url-encoded-password@postgres:5432/nodera?schema=public

# Public origin. TLS terminates at the host reverse proxy.
APP_URL=https://nodera.example
WEB_BIND_ADDRESS=127.0.0.1
WEB_PORT=3000

# Generate each secret independently with:
# node -e "console.log(require('node:crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-a-64-character-random-secret
PROVIDER_ENROLL_SECRET=replace-with-a-different-64-character-random-secret

# Google OAuth web client for APP_URL.
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret

# Cloudflare R2 Object Read & Write credentials scoped to the Nodera bucket.
R2_ACCOUNT_ID=replace-with-r2-account-id
R2_BUCKET=nodera
R2_ACCESS_KEY_ID=replace-with-r2-access-key-id
R2_SECRET_ACCESS_KEY=replace-with-r2-secret-access-key
R2_ENDPOINT=https://replace-with-r2-account-id.r2.cloudflarestorage.com
R2_REGION=auto
