{
  "name": "nodera",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "workers/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @nodera/web",
    "dev:web": "npm run dev -w @nodera/web",
    "build": "npm run build -w @nodera/web",
    "start": "npm run start -w @nodera/web",
    "lint": "npm run lint -w @nodera/web",
    "seed": "node --env-file-if-exists=.env scripts/seed.js"
  }
}
