{
  "name": "nodera",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "workers/*"
  ],
  "scripts": {
    "dev": "node scripts/dev-web.js dev",
    "dev:web": "node scripts/dev-web.js dev",
    "dev:all": "node scripts/dev-all.js",
    "build": "npm run build -w @nodera/web",
    "start": "npm run start -w @nodera/web",
    "start:production:web": "node scripts/start-production.js web",
    "start:production:dispatcher": "node scripts/start-production.js dispatcher",
    "migrate:deploy": "node scripts/start-production.js migrate",
    "lint": "npm run lint -w @nodera/web",
    "seed": "node --env-file-if-exists=.env scripts/seed.js",
    "onboarding:report": "node scripts/onboarding-report.js",
    "smoke": "node scripts/smoke.js",
    "smoke:r2": "node scripts/r2-smoke.js",
    "test": "node scripts/run-tests.js",
    "test:multi": "node scripts/test-multi-provider.js",
    "webhook:listen": "node scripts/webhook-receiver.js",
    "postinstall": "prisma generate"
  }
}
